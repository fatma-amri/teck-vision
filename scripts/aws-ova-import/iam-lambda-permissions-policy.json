{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::ctf-tekup",
        "arn:aws:s3:::ctf-tekup/ctf_ovas/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "ec2:ImportImage",
        "ec2:DescribeImportImageTasks",
        "ec2:CreateTags"
      ],
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::853169228413:role/vmimport"
    },
    {
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:Scan",
        "dynamodb:GetItem"
      ],
      "Resource": "arn:aws:dynamodb:eu-west-3:853169228413:table/ctf-ova-imports"
    }
  ]
}
